# Copy this file to `.env` and fill in your values.
# Every builder, server, and agent script reads exactly these seven variables.
# `/v1` is appended to a base URL automatically if missing.

# --- LLM (chat-completions) endpoint ---
OPENAI_BASE_URL=https://api.minimax.io/v1
OPENAI_API_KEY=replace-me
OPENAI_MODEL=MiniMax-M2.7

# --- Embeddings endpoint (e.g. local llama.cpp server) ---
EMBEDDING_BASE_URL=http://127.0.0.1:8080/v1
EMBEDDING_MODEL=bge-m3-Q8_0

# --- Reranker endpoint (used by retrievers that rerank at query time) ---
RERANKER_BASE_URL=http://127.0.0.1:8080/v1
RERANKER_MODEL=bge-reranker-v2-m3
